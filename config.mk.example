# Copy this file to config.mk and adjust paths for your CUDA/NVHPC system.

NVFORTRAN ?= nvfortran
NVC ?= nvc
NVCXX ?= nvc++

# A100 server setting used for this extract:
#   CUDA_HOME ?= /apps/cuda/12.9.1
# Keep the generic placeholder below if this repo is moved to another system.
CUDA_HOME ?= /path/to/cuda
CUDA_INC_PATH ?= $(CUDA_HOME)/include
CUDA_LIB_PATH ?= $(CUDA_HOME)/lib64

# CUDA 12+ usually provides NVTX through headers and does not require
# libnvToolsExt at link time. If your older CUDA environment still provides
# and requires it, enable the next line.
# NVTX_LIBS ?= -lnvToolsExt

# Required for the AmgX core solver path.
# Repo-local install through Make. These values are used by:
#   make amgx-install
#   make lib-amgx
# Default for this repo: `make amgx-install` installs AmgX here.
AMGX_DIR ?= $(CURDIR)/amgx_local/install
# If you use an already installed external AmgX instead, replace AMGX_DIR with
# that install prefix. It must contain include/ and lib/libamgxsh.so.
#   AMGX_DIR ?= /path/to/existing/amgx
AMGX_SRC_DIR ?= $(CURDIR)/amgx_local/source
AMGX_BUILD_DIR ?= $(CURDIR)/amgx_local/build
AMGX_CUDA_ARCH ?= 80
AMGX_GIT_URL ?= https://github.com/NVIDIA/AMGX.git
AMGX_GIT_REF ?= main
AMGX_NO_MPI ?= ON
AMGX_BUILD_JOBS ?=

BUILD_DIR ?= build
